/* ===== 趋势图卡片 ===== */
.trend-card {
  margin: 32rpx 32rpx 0;
  padding: 32rpx 24rpx;
  border-radius: 32rpx;
  background: #fff;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.trend-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A2E;
  margin-bottom: 24rpx;
}

.trend-chart-wrap {
  width: 100%;
  height: 240rpx;
}

.trend-ec {
  display: block;
  width: 100%;
  height: 240rpx;
}

/* ===== 热力图卡片 ===== */
.heatmap-card {
  margin: 32rpx 32rpx 0;
  padding: 32rpx 24rpx;
  border-radius: 32rpx;
  background: #fff;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.heatmap-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.heatmap-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A2E;
}

.heatmap-legend {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.legend-label {
  font-size: 20rpx;
  color: #8A8A9A;
}

.legend-cell {
  width: 20rpx;
  height: 20rpx;
  border-radius: 4rpx;
}

.heatmap-ec {
  display: block;
  width: 100%;
  height: 200rpx;
}

/* ===== 环形图行 ===== */
.rings-row {
  display: flex;
  gap: 24rpx;
  margin: 32rpx 32rpx 0;
}

.ring-card {
  flex: 1;
  padding: 32rpx 20rpx;
  border-radius: 32rpx;
  background: #fff;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.ring-card-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #1A1A2E;
  margin-bottom: 24rpx;
  text-align: center;
}

.ring-chart-wrap {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ring-ec {
  display: block;
  width: 200rpx;
  height: 200rpx;
}

.ring-center-text {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.ring-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #4A90D9;
}

.ring-sub-label {
  font-size: 22rpx;
  color: #8A8A9A;
  margin-top: 16rpx;
  text-align: center;
}
