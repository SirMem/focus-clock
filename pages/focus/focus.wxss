/* ===== 自定义导航栏 ===== */
.nav-shell {
  flex-shrink: 0;
  position: relative;
  z-index: 100;
  background: #fff;
  border-bottom: 1rpx solid #F0F2F5;
}

.status-spacer {
  width: 100%;
  background: #fff;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  background: #fff;
}

.nav-left,
.nav-right {
  width: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A2E;
}

/* ===== 页面容器（flex 撑满全屏，阻止滚动穿透） ===== */
.page-wrapper {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F5F7FA;
  overflow: hidden;
}

/* ===== 页面滚动容器 ===== */
.page-scroll {
  flex: 1;
  height: 0;
  overflow-y: scroll;
  -webkit-overflow-scrolling: touch;
  background: #F5F7FA;
}

/* ===== 计时器区域 ===== */
.timer-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 0 48rpx;
}

.current-task {
  margin-top: 32rpx;
  padding: 0 48rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.task-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #4A4A6A;
  text-align: center;
}

/* ===== 音效选择 ===== */
.sound-section {
  padding: 0 32rpx 32rpx;
}

.sound-scroll {
  display: flex;
  flex-direction: row;
  white-space: nowrap;
  overflow: hidden;
  padding-bottom: 4rpx;
}

.sound-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 24rpx;
  margin-right: 16rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 500;
  line-height: 1.2;
  background: #F0F2F5;
  color: #8A8A9A;
  border: 4rpx solid transparent;
  box-sizing: border-box;
  transition: all 0.2s;
}

.sound-active {
  background: #fff;
  color: #4A90D9;
  border-color: #4A90D9;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 217, 0.20);
}

/* ===== 控制按钮 ===== */
.controls-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 40rpx;
  padding: 0 48rpx 48rpx;
}

.ctrl-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.2s;
  border: none;
}

.ctrl-btn:active {
  transform: scale(0.95);
}

.ctrl-btn-secondary {
  width: 112rpx;
  height: 112rpx;
  background: #fff;
  border: 4rpx solid #E0E4EA;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.ctrl-btn-primary {
  width: 160rpx;
  height: 160rpx;
}

.ctrl-icon {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ctrl-icon image {
  width: 40rpx;
  height: 40rpx;
}

.ctrl-icon-primary {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ctrl-icon-primary image {
  width: 48rpx;
  height: 48rpx;
}

/* ===== 番茄进度点 ===== */
.progress-dots {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 32rpx;
}

.dots-row {
  display: flex;
  gap: 16rpx;
}

.dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  transition: all 0.3s;
}

.dot-active {
  background: #4A90D9;
  transform: scale(1.2);
}

.dots-label {
  font-size: 24rpx;
  color: #8A8A9A;
  margin-top: 16rpx;
}

/* ===== 统计数据 ===== */
.stats-row {
  display: flex;
  gap: 16rpx;
  padding: 0 32rpx 32rpx;
}

.stat-card {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  border-radius: 32rpx;
  background: #fff;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.stat-icon {
  font-size: 40rpx;
  line-height: 1;
}

.stat-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #8A8A9A;
}

.stat-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #1A1A2E;
}

/* ===== 模式切换 ===== */
.mode-toggle {
  display: flex;
  margin: 0 32rpx 32rpx;
  padding: 8rpx;
  border-radius: 24rpx;
  background: #fff;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.mode-btn {
  flex: 1;
  padding: 20rpx 0;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  transition: all 0.2s;
}

.mode-btn-active {
  color: #fff;
  font-weight: 600;
}

/* ===== AI教练卡片 ===== */
.ai-card {
  margin: 0 32rpx 48rpx;
  padding: 32rpx;
  border-radius: 32rpx;
  background: #fff;
  box-shadow: 0 4rpx 32rpx rgba(74, 144, 217, 0.10);
}

.ai-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.ai-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4A90D9, #6C5CE7);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #fff;
  font-weight: 700;
}

.ai-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A2E;
}

.ai-badge {
  margin-left: auto;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  background: #EBF4FF;
  color: #4A90D9;
  font-size: 22rpx;
  line-height: 1.4;
  font-weight: 500;
}

.ai-tip {
  font-size: 28rpx;
  line-height: 1.6;
  color: #4A4A6A;
}

.bottom-scroll-space {
  height: calc(32rpx + env(safe-area-inset-bottom));
}

/* ===== 任务选择器弹层 ===== */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 200;
  background: rgba(0, 0, 0, 0.4);
}

.picker-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 201;
  max-height: 60vh;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  display: flex;
  flex-direction: column;
}

.picker-show {
  transform: translateY(0);
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 16rpx;
  flex-shrink: 0;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A2E;
}

.picker-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.picker-list {
  flex: 1;
  padding: 0 32rpx;
  overflow-y: scroll;
  -webkit-overflow-scrolling: touch;
}

.picker-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F0F2F5;
}

.picker-item:active {
  opacity: 0.7;
}

.picker-item-active {
  background: transparent;
}

.picker-item-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.picker-item-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #1A1A2E;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.picker-item-meta {
  font-size: 22rpx;
  color: #8A8A9A;
}

.picker-empty {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 64rpx 32rpx;
}

.picker-empty-text {
  font-size: 28rpx;
  color: #8A8A9A;
}

/* ===== 当前任务（可点击） ===== */
.current-task-empty {
  padding: 12rpx 24rpx;
  border: 2rpx dashed #D0D4DB;
  border-radius: 999rpx;
}

.task-text-empty {
  font-size: 28rpx;
  font-weight: 500;
  color: #4A90D9;
}
