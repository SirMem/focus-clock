<!-- ===== 页面容器（flex 撑满全屏，阻止滚动穿透） ===== -->
<view class="page-wrapper">

  <!-- ===== 自定义导航栏 ===== -->
  <view class="nav-shell">
    <view class="status-spacer" style="height: {{statusBarHeight}}px;"></view>
    <view class="nav-bar" style="height: {{capsuleHeight}}px;">
      <view class="nav-left">
        <view class="nav-placeholder"></view>
      </view>
      <view class="nav-title">专注时钟</view>
      <view class="nav-right" bind:tap="onMenuTap">
        <t-icon name="more" size="44rpx" color="#8A8A9A" />
      </view>
    </view>
  </view>

  <!-- ===== 计时器区域（固定在导航下方，不参与滚动） ===== -->
  <view class="timer-section">
    <circular-timer
      progress="{{progress}}"
      mode="{{mode}}"
      timeLeft="{{timeLeft}}"
      state="{{timerState}}"
    />
    <view class="current-task" bind:tap="onTaskPickerOpen" wx:if="{{selectedTaskId}}">
      <text class="task-text">{{currentTask}}</text>
      <t-icon name="chevron-down" size="28rpx" color="#8A8A9A" />
    </view>
    <view class="current-task current-task-empty" bind:tap="onTaskPickerOpen" wx:else>
      <text class="task-text-empty">选择待办任务</text>
      <t-icon name="add" size="28rpx" color="#4A90D9" />
    </view>
  </view>

  <!-- ===== 可滚动内容区域（flex:1 占满剩余高度） ===== -->
  <scroll-view class="page-scroll" scroll-y enhanced show-scrollbar="{{false}}">

    <!-- 音效选择 -->
    <view class="sound-section">
      <scroll-view class="sound-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view
          wx:for="{{sounds}}"
          wx:key="id"
          class="sound-item {{item.id === currentSound ? 'sound-active' : ''}}"
          bind:tap="onSoundTap"
          data-id="{{item.id}}"
        >
          <text>{{item.label}}</text>
        </view>
      </scroll-view>
    </view>

    <!-- 控制按钮（t-icon 替代 data:image/svg+xml） -->
    <view class="controls-row">
      <view class="ctrl-btn ctrl-btn-secondary" bind:tap="onReset">
        <t-icon name="refresh" size="40rpx" color="#8A8A9A" />
      </view>

      <view class="ctrl-btn ctrl-btn-primary" style="background: linear-gradient(135deg, {{modeColor}}, {{darkerColor}}); box-shadow: 0 8rpx 32rpx {{modeColor}}50;" bind:tap="onPlayPause">
        <t-icon wx:if="{{timerState === 'running'}}" name="pause-circle-stroke" size="48rpx" color="#fff" />
        <t-icon wx:else name="play-circle-stroke" size="48rpx" color="#fff" />
      </view>

      <view class="ctrl-btn ctrl-btn-secondary" bind:tap="onSkip">
        <t-icon name="next" size="40rpx" color="#8A8A9A" />
      </view>
    </view>

    <!-- 番茄进度点 -->
    <view class="progress-dots">
      <view class="dots-row">
        <view
          wx:for="{{4}}"
          wx:key="*this"
          class="dot {{index < sessions % 4 ? 'dot-active' : ''}}"
          style="background: {{index < sessions % 4 ? '#4A90D9' : '#D0D4DB'}}; transform: {{index < sessions % 4 ? 'scale(1.2)' : 'scale(1)'}}"
        ></view>
      </view>
      <text class="dots-label">
        今日已完成 <text style="color:#4A90D9;font-weight:600">{{sessions}}</text> 个番茄
      </text>
    </view>

    <!-- 统计数据 -->
    <view class="stats-row">
      <view class="stat-card" wx:for="{{statItems}}" wx:key="label">
        <text class="stat-icon">{{item.icon}}</text>
        <view class="stat-info">
          <text class="stat-label">{{item.label}}</text>
          <text class="stat-value">{{item.value}}</text>
        </view>
      </view>
    </view>

    <!-- 模式切换 -->
    <view class="mode-toggle">
      <view
        wx:for="{{modes}}"
        wx:key="mode"
        class="mode-btn {{item.mode === mode ? 'mode-btn-active' : ''}}"
        style="background: {{item.mode === mode ? modeColor : 'transparent'}}; color: {{item.mode === mode ? '#fff' : '#8A8A9A'}}"
        bind:tap="onModeSwitch"
        data-mode="{{item.mode}}"
      >
        <text>{{item.label}}</text>
      </view>
    </view>

    <!-- AI 教练卡片 -->
    <view class="ai-card">
      <view class="ai-header">
        <view class="ai-avatar">AI</view>
        <text class="ai-title">AI 教练</text>
        <view class="ai-badge {{aiGeneratedBy === 'ai' ? 'ai-badge-ai' : aiGeneratedBy === 'rule' ? 'ai-badge-rule' : ''}}">
          <block wx:if="{{aiGeneratedBy === 'ai'}}">AI 建议</block>
          <block wx:elif="{{aiGeneratedBy === 'rule'}}">智能建议</block>
          <block wx:else>专注指南</block>
        </view>
      </view>
      <text class="ai-tip">{{currentTip}}</text>
    </view>


    <view class="bottom-scroll-space"></view>
  </scroll-view>

  <!-- ===== 任务选择器弹层 ===== -->
  <view class="picker-mask" wx:if="{{showTaskPicker}}" bind:tap="onTaskPickerClose"></view>
  <view class="picker-panel {{showTaskPicker ? 'picker-show' : ''}}">
    <view class="picker-header">
      <text class="picker-title">选择待办任务</text>
      <view bind:tap="onTaskPickerClose" class="picker-close">
        <t-icon name="close" size="32rpx" color="#8A8A9A" />
      </view>
    </view>
    <scroll-view class="picker-list" scroll-y enhanced show-scrollbar="{{false}}">
      <view
        wx:for="{{availableTasks}}"
        wx:key="id"
        class="picker-item {{item.id === selectedTaskId ? 'picker-item-active' : ''}}"
        bind:tap="onTaskSelect"
        data-id="{{item.id}}"
      >
        <view class="picker-item-info">
          <text class="picker-item-text">{{item.text}}</text>
          <text class="picker-item-meta">{{item.completed}}/{{item.pomodoros}} 🍅</text>
        </view>
        <t-icon wx:if="{{item.id === selectedTaskId}}" name="check" size="32rpx" color="#4A90D9" />
      </view>
    </scroll-view>
    <view class="picker-empty" wx:if="{{availableTasks.length === 0}}">
      <text class="picker-empty-text">暂无待办，请先去待办页添加任务</text>
    </view>
  </view>

</view>
