/* ===== 周期选择器 ===== */
.period-selector {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx 0;
}

.period-btn {
  flex: 1;
  padding: 16rpx 0;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: 500;
  text-align: center;
  background: #fff;
  color: #8A8A9A;
  border: 2rpx solid #E0E4EA;
  transition: all 0.2s;
}

.period-active {
  background: #4A90D9;
  color: #fff;
  border-color: #4A90D9;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 217, 0.25);
}

/* ===== 摘要卡片行 ===== */
.summary-row {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx 0;
}

.summary-card {
  flex: 1;
  padding: 24rpx;
  border-radius: 32rpx;
  background: #fff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.summary-icon {
  font-size: 32rpx;
  line-height: 1;
}

.summary-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A2E;
  line-height: 1.2;
  margin-top: 4rpx;
}

.summary-label {
  font-size: 22rpx;
  color: #8A8A9A;
  line-height: 1;
}

.summary-trend {
  display: flex;
  align-items: center;
  gap: 4rpx;
  margin-top: 4rpx;
}

.trend-arrow {
  font-size: 18rpx;
  line-height: 1;
}

.arrow-up { color: #34C759; }
.arrow-down { color: #FF3B30; }

.trend-text {
  font-size: 22rpx;
  font-weight: 600;
}

/* ===== 趋势卡片 ===== */
.trend-card {
  position: relative;
  overflow: hidden;
  margin: 24rpx 32rpx 0;
  padding: 32rpx;
  border-radius: 32rpx;
  background: #fff;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.trend-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A2E;
  margin-bottom: 24rpx;
}

/* ECharts 面积图 */
.trend-ec {
  width: 100%;
  height: 300rpx;
  display: block;
}

/* ===== 热力图卡片 ===== */
.heatmap-card {
  position: relative;
  overflow: hidden;
  margin: 24rpx 32rpx 0;
  padding: 32rpx;
  border-radius: 32rpx;
  background: #fff;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.heatmap-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.heatmap-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A2E;
}

.heatmap-legend {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.legend-label {
  font-size: 20rpx;
  color: #8A8A9A;
}

.legend-cell {
  width: 20rpx;
  height: 20rpx;
  border-radius: 4rpx;
}

/* ECharts 热力图 */
.heatmap-ec {
  width: 100%;
  height: 380rpx;
  display: block;
}

/* ===== 环形图行 ===== */
.rings-row {
  display: flex;
  gap: 24rpx;
  margin: 24rpx 32rpx 0;
}

.ring-card {
  position: relative;
  overflow: hidden;
  flex: 1;
  padding: 32rpx;
  border-radius: 32rpx;
  background: #fff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.ring-card-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #1A1A2E;
  margin-bottom: 24rpx;
  text-align: center;
}

.ring-chart-wrap {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ECharts 环图 */
.ring-ec {
  display: block;
  width: 200rpx;
  height: 200rpx;
}

.ring-center-text {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.ring-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #4A90D9;
}

.ring-legend {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  margin-top: 16rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.legend-text {
  font-size: 22rpx;
  color: #8A8A9A;
}

.ring-sub-label {
  font-size: 22rpx;
  color: #8A8A9A;
  margin-top: 16rpx;
  text-align: center;
}

/* ===== 评分卡片 ===== */
.score-card {
  margin: 24rpx 32rpx 0;
  padding: 40rpx;
  border-radius: 32rpx;
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, #4A90D9 0%, #6C5CE7 100%);
  box-shadow: 0 16rpx 48rpx rgba(74, 144, 217, 0.3);
}

.score-card::before {
  content: '';
  position: absolute;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.1);
  top: -60rpx;
  right: -40rpx;
}

.score-card::after {
  content: '';
  position: absolute;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.1);
  bottom: -40rpx;
  left: -20rpx;
}

.score-left {
  position: relative;
  z-index: 1;
}

.score-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  font-weight: 500;
}

.score-value-wrap {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin-top: 8rpx;
}

.score-value {
  font-size: 84rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
}

.score-unit {
  font-size: 36rpx;
  color: #fff;
}

.score-emoji {
  position: absolute;
  right: 40rpx;
  top: 40rpx;
  font-size: 72rpx;
  opacity: 0.2;
  z-index: 1;
}

.score-footer {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 24rpx;
  position: relative;
  z-index: 1;
}

.score-ai-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.9);
}

/* ===== 日记入口 ===== */
.journal-entry {
  margin: 24rpx 32rpx 0;
  padding: 32rpx;
  border-radius: 32rpx;
  background: #fff;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: all 0.2s;
}

.journal-entry:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.journal-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.journal-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  background: #F0F7FF;
  display: flex;
  align-items: center;
  justify-content: center;
}

.journal-icon {
  font-size: 36rpx;
}

.journal-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.journal-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A2E;
}

.journal-desc {
  font-size: 22rpx;
  color: #8A8A9A;
}

/* ===== 页面基础 ===== */
.page-wrapper {
  min-height: 100vh;
  background: #F5F7FA;
  display: flex;
  flex-direction: column;
}

.page-scroll {
  flex: 1;
  padding-bottom: 40rpx;
}

.bottom-scroll-space {
  height: 120rpx;
}

/* ===== 导航栏 ===== */
.nav-shell {
  position: sticky;
  top: 0;
  z-index: 99;
  background: #F5F7FA;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1A1A2E;
}

.nav-right {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}
