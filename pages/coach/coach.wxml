<view class="page-wrapper">

  <!-- ===== 自定义导航栏 ===== -->
  <view class="nav-shell">
    <view class="status-spacer" style="height: {{statusBarHeight}}px;"></view>
    <view class="nav-bar" style="height: {{capsuleHeight}}px;">
      <view class="nav-left">
        <view class="nav-placeholder"></view>
      </view>
      <view class="nav-title">AI 教练</view>
      <view class="nav-right" bind:tap="onMenuTap">
        <t-icon name="more" size="44rpx" color="#8A8A9A" />
      </view>
    </view>
  </view>

  <scroll-view class="page-scroll" scroll-y enhanced show-scrollbar="{{false}}">

    <!-- ===== AI 评分卡 ===== -->
    <view class="ai-hero-card">
      <view class="hero-deco-1"></view>
      <view class="hero-deco-2"></view>
      <view class="hero-content">
        <view class="hero-left">
          <text class="hero-label">今日效率评分</text>
          <view class="hero-score-wrap">
            <text class="hero-score">92</text>
            <text class="hero-score-unit">分</text>
          </view>
          <view class="hero-badge-row">
            <view class="hero-badge">
              <text class="hero-badge-icon-text">↑</text>
              <text class="hero-badge-text">+5 分</text>
            </view>
            <text class="hero-badge-desc">较昨日</text>
          </view>
        </view>
        <view class="hero-avatar">
          <text class="hero-avatar-text">🤖</text>
        </view>
      </view>
    </view>

    <!-- ===== 趋势洞察 ===== -->
    <view class="insight-card">
      <view class="insight-header">
        <text class="insight-icon">📊</text>
        <text class="insight-title">趋势洞察</text>
      </view>
      <text class="insight-text">
        你这周专注时长比上周提升了<text class="insight-highlight-green">15%</text>，
        <text class="insight-highlight-blue">周三上午</text>是你的效率高峰时段。继续加油！
      </text>
      <!-- Sparkline SVG -->
      <view class="sparkline-wrap">
        <view class="sparkline">
          <svg width="100%" height="100%" viewBox="0 0 280 64">
            <path
              d="M0,52 L46.67,40 L93.33,45.33 L140,32 L186.67,21.33 L233.33,17.33 L280,10.67"
              fill="none" stroke="#4A90D9" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"
            />
            <path
              d="M0,52 L46.67,40 L93.33,45.33 L140,32 L186.67,21.33 L233.33,17.33 L280,10.67"
              fill="url(#sparklineGradient)"
              opacity="0.15"
            />
            <defs>
              <linearGradient id="sparklineGradient" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#4A90D9" />
                <stop offset="100%" stop-color="#fff" stop-opacity="0" />
              </linearGradient>
            </defs>
          </svg>
        </view>
      </view>
      <view class="sparkline-footer">
        <text class="sparkline-label">本周趋势</text>
        <text class="sparkline-up">↑ 15%</text>
      </view>
    </view>

    <!-- ===== 今日建议 ===== -->
    <view class="suggestion-card">
      <view class="suggestion-header">
        <text class="suggestion-icon">💡</text>
        <text class="suggestion-title">今日建议</text>
      </view>
      <text class="suggestion-text">
        建议明天把最难的任务安排在<text class="suggestion-highlight">9-11点</text>，
        这是你本周效率最高的时段。
      </text>
      <view
        class="suggestion-btn {{suggestionAccepted ? 'suggestion-btn-disabled' : ''}}"
        bind:tap="onAcceptSuggestion"
      >
        <text>{{suggestionAccepted ? '✓ 已采纳' : '采纳建议'}}</text>
      </view>
    </view>

    <!-- ===== 成就徽章 ===== -->
    <view class="achievement-section">
      <view class="achievement-header">
        <text class="achievement-title">成就徽章</text>
        <view class="achievement-view-all" bind:tap="onViewAllAchievements">
          <text>查看全部</text>
        </view>
      </view>
      <view class="achievement-grid">
        <view
          wx:for="{{achievements}}"
          wx:key="index"
          class="achievement-item"
        >
          <view
            class="achievement-icon-wrap"
            style="background: {{item.bgColor}};"
          >
            <text class="achievement-icon">{{item.icon}}</text>
          </view>
          <text class="achievement-label">{{item.label}}</text>
          <text class="achievement-value" style="color: {{item.color}};">{{item.value}}</text>
        </view>
      </view>
    </view>

    <!-- ===== 周报预览 ===== -->
    <view class="weekly-card">
      <view class="weekly-header">
        <text class="weekly-title">周报预览</text>
        <view class="weekly-view-all" bind:tap="onViewWeeklyReport">
          <text>查看完整周报</text>
          <t-icon name="chevron-right" size="24rpx" color="#4A90D9" />
        </view>
      </view>

      <!-- Bar Chart (CSS) -->
      <view class="weekly-chart">
        <view
          wx:for="{{weeklyTrend}}"
          wx:key="index"
          class="weekly-bar-col"
        >
          <view class="weekly-bar-track">
            <view
              class="weekly-bar-fill"
              style="height: {{item.height}}%;"
            ></view>
          </view>
          <text class="weekly-bar-label">{{item.day}}</text>
        </view>
      </view>

      <!-- 统计摘要 -->
      <view class="weekly-stats">
        <view class="weekly-stat-item" wx:for="{{weeklyStats}}" wx:key="label">
          <text class="weekly-stat-value">{{item.value}}</text>
          <text class="weekly-stat-label">{{item.label}}</text>
        </view>
      </view>
    </view>

    <!-- ===== 历史建议 ===== -->
    <view class="history-suggestions">
      <text class="history-suggestions-title">历史建议</text>
      <view class="history-suggestions-list">
        <view
          wx:for="{{coachingHistory}}"
          wx:key="index"
          class="history-suggestion-item"
        >
          <view class="history-suggestion-icon {{item.accepted ? 'history-icon-accepted' : ''}}">
            <text>{{item.accepted ? '✓' : '💡'}}</text>
          </view>
          <view class="history-suggestion-content">
            <text class="history-suggestion-date">{{item.date}}</text>
            <text class="history-suggestion-text">{{item.text}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- ===== AI 教练设置 ===== -->
    <view class="coach-settings">
      <view class="coach-settings-btn" bind:tap="onCoachSettings">
        <view class="coach-settings-left">
          <view class="coach-settings-icon-wrap">
            <text class="coach-settings-icon">⚙️</text>
          </view>
          <view class="coach-settings-info">
            <text class="coach-settings-label">AI 教练设置</text>
            <text class="coach-settings-desc">个性化建议偏好</text>
          </view>
        </view>
        <t-icon name="chevron-right" size="28rpx" color="#C0C4CC" />
      </view>
    </view>

    <view class="bottom-scroll-space"></view>
  </scroll-view>

</view>
