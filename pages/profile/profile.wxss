/* ===== 个人信息卡片 ===== */
.profile-card {
  margin: 32rpx 32rpx 0;
  padding: 40rpx;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #667EEA 100%);
  box-shadow: 0 16rpx 48rpx rgba(74, 144, 217, 0.25);
}

.profile-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar-wrap {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  flex-shrink: 0;
  overflow: hidden;
  transition: all 0.2s;
}

.avatar-wrap:active {
  transform: scale(0.95);
}

/* chooseAvatar 按钮 — 重置默认样式，保持与 avatar-wrap 一致 */
.avatar-btn {
  width: 128rpx !important;
  height: 128rpx !important;
  border-radius: 50% !important;
  flex-shrink: 0;
  overflow: hidden;
  padding: 0 !important;
  margin: 0 !important;
  border: none !important;
  background: transparent !important;
  line-height: 1 !important;
  transition: all 0.2s;
}

.avatar-btn::after {
  border: none !important;
}

.avatar-btn:active {
  transform: scale(0.95);
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-content {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-guest {
  background: rgba(255,255,255,0.2);
}

.avatar-emoji {
  font-size: 56rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

/* 昵称输入框 — 与 .user-name 视觉一致 */
.nickname-input {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
  padding: 0;
  background: transparent;
  border: none;
  height: auto;
  min-height: auto;
}

.nickname-input::placeholder {
  color: rgba(255,255,255,0.5);
}

.user-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

.settings-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.settings-btn:active {
  transform: scale(0.9);
}

.profile-save-btn {
  width: 100%;
  height: 72rpx;
  margin: 28rpx 0 0;
  padding: 0;
  border-radius: 20rpx !important;
  background: rgba(255,255,255,0.18);
  color: rgba(255,255,255,0.8);
  font-size: 26rpx;
  font-weight: 500;
  line-height: 72rpx;
  border: none;
}

.profile-save-btn::after {
  border: none;
}

.profile-save-btn-active {
  background: #fff;
  color: #4A90D9;
}

.profile-save-btn[disabled] {
  opacity: 0.75;
  color: rgba(255,255,255,0.7);
  background: rgba(255,255,255,0.14);
}

/* ===== 统计摘要 ===== */
.stats-summary {
  display: flex;
  gap: 16rpx;
  margin: 32rpx 32rpx 0;
}

.summary-item {
  flex: 1;
  padding: 24rpx;
  border-radius: 32rpx;
  background: #fff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.summary-icon {
  font-size: 40rpx;
}

.summary-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #4A90D9;
}

.summary-label {
  font-size: 22rpx;
  color: #8A8A9A;
}

/* ===== 目标卡片 ===== */
.goal-card {
  margin: 24rpx 32rpx 0;
  padding: 32rpx;
  border-radius: 32rpx;
  background: #fff;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.goal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.goal-title-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.goal-icon {
  font-size: 36rpx;
}

.goal-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A2E;
}

.goal-pct {
  font-size: 28rpx;
  font-weight: 600;
  color: #4A90D9;
}

.goal-subtitle {
  display: block;
  font-size: 24rpx;
  color: #8A8A9A;
  margin-bottom: 16rpx;
}

.goal-progress-bar {
  width: 100%;
  height: 16rpx;
  border-radius: 999rpx;
  background: #E0E4EA;
  overflow: hidden;
}

.goal-progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #4A90D9, #667EEA);
  transition: width 0.5s;
}

.goal-remain {
  display: block;
  font-size: 22rpx;
  color: #8A8A9A;
  margin-top: 16rpx;
}

/* ===== 菜单区域 ===== */
.menu-section {
  padding: 32rpx 32rpx 0;
}

.menu-section-title {
  display: block;
  font-size: 22rpx;
  font-weight: 600;
  color: #8A8A9A;
  padding: 0 16rpx;
  margin-bottom: 16rpx;
}

.menu-card {
  border-radius: 32rpx;
  background: #fff;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 0 32rpx;
  height: 112rpx;
  transition: all 0.2s;
  border-top: 2rpx solid #F0F2F5;
}

.menu-item:first-child {
  border-top: none;
}

.menu-item:active {
  background: #F8F9FA;
}

.menu-item-icon {
  font-size: 36rpx;
  flex-shrink: 0;
}

.menu-item-content {
  flex: 1;
  min-width: 0;
}

.menu-item-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #1A1A2E;
}

.menu-item-desc {
  display: block;
  font-size: 22rpx;
  color: #8A8A9A;
  margin-top: 4rpx;
}

.menu-item-badge {
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 500;
}

/* ===== 开关 ===== */
.menu-switch {
  width: 88rpx;
  height: 48rpx;
  border-radius: 999rpx;
  background: #E0E4EA;
  padding: 4rpx;
  transition: all 0.2s;
  position: relative;
}

.switch-on {
  background: #34C759;
}

.switch-knob {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.15);
  transition: all 0.2s;
}

.switch-on .switch-knob {
  transform: translateX(40rpx);
}

/* ===== 退出登录 ===== */
.logout-section {
  padding: 32rpx 32rpx 0;
}

.logout-btn {
  width: 100%;
  padding: 24rpx 0;
  border-radius: 32rpx;
  background: #fff;
  color: #FF3B30;
  font-size: 26rpx;
  font-weight: 500;
  text-align: center;
  border: 3rpx solid #FFE5E5;
  transition: all 0.2s;
}

.logout-btn:active {
  transform: scale(0.98);
}

.version-text {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #C0C4CC;
  margin-top: 48rpx;
}

/* ════════════════════════════════════════════════════
   🆕 子视图容器 — 独立滚动区域
   ════════════════════════════════════════════════════ */

.sub-view {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

/* 子视图导航栏（带底部边框，与 Figma 一致） */
.sub-view-nav {
  border-bottom: 2rpx solid #F0F2F5;
}

/* 子视图导航栏标题（与 Figma SubPageHeader 视觉一致） */
.sub-nav-title {
  color: #1A1A2E !important;
  font-size: 32rpx !important;
}

/* 子视图返回按钮 */
.nav-back-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #F5F7FA;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.nav-back-btn:active {
  transform: scale(0.9);
}

/* ════════════════════════════════════════════════════
   🆕 子视图占位内容（后续 ticket 将替换为真实界面）
   ════════════════════════════════════════════════════ */

.sub-view-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 64rpx;
  gap: 16rpx;
}

.placeholder-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.placeholder-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A2E;
}

.placeholder-desc {
  font-size: 26rpx;
  color: #C0C4CC;
  text-align: center;
  line-height: 1.5;
}

/* ════════════════════════════════════════════════════
   🆕 个人目标子视图（GoalPage）
   ════════════════════════════════════════════════════ */

.goal-sub-view {
  background: #F5F7FA;
  padding-bottom: 32rpx;
}

/* 进度卡片 */
.goal-progress-card {
  margin: 32rpx 32rpx 0;
  padding: 32rpx 40rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #4A90D9, #667EEA);
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.25);
}

.goal-progress-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  margin-bottom: 8rpx;
}

.goal-progress-row {
  display: flex;
  align-items: flex-end;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.goal-progress-pct {
  font-size: 80rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
}

.goal-progress-unit {
  font-size: 36rpx;
  color: rgba(255,255,255,0.9);
  margin-bottom: 8rpx;
}

.goal-progress-sub {
  font-size: 24rpx;
  color: rgba(255,255,255,0.6);
  margin-bottom: 8rpx;
  margin-left: auto;
}

.goal-progress-track {
  width: 100%;
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.25);
  overflow: hidden;
  margin-bottom: 12rpx;
}

.goal-progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: #fff;
  transition: width 0.5s;
}

.goal-progress-remain {
  display: block;
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
}

/* 设置卡片 */
.goal-setting-card {
  margin: 24rpx 32rpx 0;
  padding: 32rpx;
  border-radius: 32rpx;
  background: #fff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.goal-setting-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A2E;
  margin-bottom: 4rpx;
}

.goal-setting-desc {
  display: block;
  font-size: 22rpx;
  color: #8A8A9A;
  margin-bottom: 24rpx;
}

.goal-setting-hint {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #8A8A9A;
  margin-top: 16rpx;
}

/* 专注时长按钮网格 */
.goal-duration-grid {
  display: grid;
  gap: 16rpx;
  grid-template-columns: repeat(3, 1fr);
}

.goal-duration-btn {
  padding: 20rpx;
  border-radius: 20rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
  color: #4A4A6A;
  background: #F0F2F5;
  transition: all 0.2s;
}

.goal-duration-btn:active {
  transform: scale(0.95);
}

.duration-active {
  background: #4A90D9;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(74, 144, 217, 0.3);
}

/* 步进器 */
.goal-stepper-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.goal-stepper-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s;
}

.goal-stepper-btn:active {
  transform: scale(0.9);
}

.goal-stepper-sub {
  background: #F0F2F5;
}

.goal-stepper-add {
  background: #4A90D9;
}

.stepper-sign {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1;
}

.goal-stepper-sub .stepper-sign {
  color: #4A4A6A;
}

.goal-stepper-add .stepper-sign {
  color: #fff;
}

.goal-stepper-value-wrap {
  flex: 1;
  text-align: center;
}

.goal-stepper-value {
  font-size: 64rpx;
  font-weight: 700;
  color: #4A90D9;
  line-height: 1;
}

.goal-stepper-unit {
  font-size: 24rpx;
  color: #8A8A9A;
  margin-left: 8rpx;
}

/* 快速预设 */
.goal-preset-row {
  display: flex;
  gap: 16rpx;
}

.goal-preset-btn {
  flex: 1;
  padding: 16rpx 0;
  border-radius: 16rpx;
  text-align: center;
  font-size: 24rpx;
  color: #8A8A9A;
  background: #F5F7FA;
  transition: all 0.2s;
}

.goal-preset-btn:active {
  transform: scale(0.95);
}

.preset-active {
  background: #EBF4FF;
  color: #4A90D9;
  font-weight: 600;
}

/* 每日番茄显示 */
.goal-daily-display {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  flex-wrap: wrap;
}

.goal-daily-emoji {
  font-size: 36rpx;
}

.goal-daily-overflow {
  font-size: 28rpx;
  font-weight: 700;
  color: #4A90D9;
  margin-left: 8rpx;
}

/* 保存按钮 */
.goal-save-section {
  margin: 32rpx 32rpx 0;
}

.goal-save-btn {
  width: 100%;
  padding: 28rpx 0;
  border-radius: 28rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  background: linear-gradient(135deg, #4A90D9, #667EEA);
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.3);
  transition: all 0.2s;
}

.goal-save-btn:active {
  transform: scale(0.98);
}

.goal-save-done {
  background: linear-gradient(135deg, #34C759, #28A745);
  box-shadow: 0 8rpx 24rpx rgba(52, 199, 89, 0.3);
}
