/* ===== 自定义导航栏 ===== */
.nav-shell {
  flex-shrink: 0;
  position: relative;
  z-index: 100;
  background: #fff;
  border-bottom: 1rpx solid #F0F2F5;
}

.status-spacer {
  width: 100%;
  background: #fff;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  background: #fff;
}

.nav-left,
.nav-right {
  width: 88rpx;
  display: flex;
  align-items: center;
}

.nav-right {
  justify-content: flex-end;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1A1A2E;
}

/* ===== 页面容器 ===== */
.page-wrapper {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
  background: #F5F7FA;
}

/* ===== 待办内容区域 ===== */
.todo-area {
  flex: 1;
  position: relative;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* ===== 快速添加输入框 ===== */
.quick-add {
  flex-shrink: 0;
  padding: 24rpx 32rpx 16rpx;
}

.quick-add-inner {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 8rpx 8rpx 8rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.add-input {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
  color: #1A1A2E;
}

.add-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #EEF0F4;
  transition: all 0.3s ease;
}

.add-btn-active {
  background: linear-gradient(135deg, #4A90D9 0%, #6C5CE7 100%);
  box-shadow: 0 4rpx 12rpx rgba(74, 144, 217, 0.35);
}

/* ===== 筛选标签 ===== */
.filter-chips {
  flex-shrink: 0;
  display: flex;
  gap: 16rpx;
  padding: 0 32rpx 16rpx;
}

.chip {
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #8A8A9A;
  background: #fff;
  border: 1rpx solid #E8E8F0;
  transition: all 0.3s ease;
}

.chip-active {
  color: #4A90D9;
  background: rgba(74, 144, 217, 0.08);
  border-color: #4A90D9;
  font-weight: 500;
}

/* ===== 任务列表（滚动区域） ===== */
.task-scroll {
  flex: 1;
  height: 0;
  padding: 0 32rpx;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.empty-icon {
  font-size: 56rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #C0C4CC;
}

/* ===== 任务列表 ===== */
.task-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-bottom: 120rpx;
}

/* ===== 滑动删除容器 ===== */
.swipe-wrap {
  position: relative;
  overflow: hidden;
  border-radius: 20rpx;
  margin: 0 32rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* 红色删除背景（渐变浅红，滑动时渐显） */
.swipe-bg {
  position: absolute;
  inset: 0;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #FF3B30 0%, #FF6B6B 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 0;
  transition: opacity 0.15s ease;
}

.swipe-bg-inner {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 可滑动前景卡片 */
.swipe-foreground {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  background: #fff;
  border-radius: 20rpx;
  transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  will-change: transform;
}

.swipe-foreground.swipe-no-trans {
  transition: none;
}

/* 滑动提示指示器（右边缘微渐变，永久暗示可滑动） */
.swipe-hint-edge {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 56rpx;
  background: linear-gradient(90deg, transparent, rgba(255, 59, 48, 0.09));
  z-index: 3;
  pointer-events: none;
  transition: opacity 0.5s ease;
}

.swipe-hint-edge.hint-fade {
  opacity: 0 !important;
  transition: opacity 0.8s ease;
}

/* 首个任务卡的提示脉冲（轻推前闪烁） */
@keyframes hint-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}
.swipe-hint-edge.hint-pulse {
  animation: hint-pulse 1s ease-in-out 2;
}

/* 勾选框 */
.task-checkbox {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 2rpx solid #4A90D9;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
  transition: all 0.3s ease;
}

.checkbox-checked {
  background: #34C759;
  border-color: #34C759;
}

/* 任务内容 */
.task-content {
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.task-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #1A1A2E;
  display: block;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.title-done {
  text-decoration: line-through;
  color: #C0C4CC;
}

.task-meta {
  display: flex;
  align-items: center;
  margin-top: 4rpx;
}

.meta-pomodoro {
  font-size: 22rpx;
  color: #FF9500;
}

/* 任务右侧操作区 */
.task-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.priority-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

/* 滑动相关样式已移至上方 .swipe-wrap / .swipe-bg / .swipe-foreground */

/* ===== 底部摘要栏 ===== */
.summary-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 32rpx;
  background: linear-gradient(to top, #F5F7FA 60%, transparent);
  z-index: 10;
  pointer-events: none;
}

.summary-left,
.summary-right {
  font-size: 24rpx;
  color: #8A8A9A;
}

.summary-num-green {
  color: #34C759;
  font-weight: 600;
}

.summary-num-blue {
  color: #4A90D9;
  font-weight: 600;
}

/* ===== 悬浮添加按钮 (FAB) ===== */
.fab-btn {
  position: absolute;
  bottom: 80rpx;
  right: 40rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4A90D9 0%, #6C5CE7 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.35);
  z-index: 20;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.fab-btn:active {
  transform: scale(0.92);
  box-shadow: 0 4rpx 12rpx rgba(74, 144, 217, 0.25);
}

/* ===== 底部占位空间 ===== */
.scroll-bottom-space {
  height: 160rpx;
}

/* ===== 底部 Tab Bar ===== */
.bottom-tab-bar {
  flex-shrink: 0;
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 12rpx 0 24rpx;
  background: #fff;
  border-top: 1rpx solid #F0F2F5;
  position: relative;
  z-index: 50;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  position: relative;
  padding: 4rpx 24rpx;
  transition: transform 0.2s ease;
}

.tab-item:active {
  transform: scale(0.95);
}

.tab-label {
  font-size: 20rpx;
  line-height: 1.2;
  font-weight: 500;
  color: #C0C4CC;
}

.tab-item-active .tab-label {
  color: #4A90D9;
}

.tab-dot {
  position: absolute;
  top: 88rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: #4A90D9;
}
