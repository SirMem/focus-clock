/* ===== 自定义导航栏 ===== */
.nav-shell {
  flex-shrink: 0;
  position: relative;
  z-index: 100;
  background: #fff;
  border-bottom: 1rpx solid #F0F2F5;
}

.status-spacer {
  width: 100%;
  background: #fff;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  background: #fff;
}

.nav-left,
.nav-right {
  width: 88rpx;
  display: flex;
  align-items: center;
}

.nav-right {
  justify-content: flex-end;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1A1A2E;
}

/* ===== 页面容器 ===== */
.page-wrapper {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
  background: #F5F7FA;
}

/* ===== 待办内容区域 ===== */
.todo-area {
  flex: 1;
  position: relative;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* ===== 快速添加输入框 ===== */
.quick-add {
  flex-shrink: 0;
  padding: 24rpx 32rpx 16rpx;
}

.quick-add-inner {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 8rpx 8rpx 8rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.add-input {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
  color: #1A1A2E;
}

.add-input:focus {
  border-color: #4A90D9;
}

.add-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #EEF0F4;
  transition: all 0.3s ease;
}

.add-btn-active {
  background: linear-gradient(135deg, #4A90D9 0%, #6C5CE7 100%);
  box-shadow: 0 4rpx 12rpx rgba(74, 144, 217, 0.35);
}

/* ===== 筛选标签 ===== */
.filter-chips {
  flex-shrink: 0;
  display: flex;
  gap: 16rpx;
  padding: 0 32rpx 16rpx;
}

.chip {
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #8A8A9A;
  background: #fff;
  border: 1rpx solid #E8E8F0;
  transition: all 0.3s ease;
}

.chip-active {
  color: #4A90D9;
  background: rgba(74, 144, 217, 0.08);
  border-color: #4A90D9;
  font-weight: 500;
}

/* ===== 任务列表（滚动区域） ===== */
.task-scroll {
  flex: 1;
  height: 0;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.empty-icon {
  font-size: 56rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #C0C4CC;
}

/* ===== 任务列表 ===== */
.task-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 0 32rpx 120rpx;
}

/* ===== 滑动删除容器 ===== */
.swipe-wrap {
  position: relative;
  overflow: hidden;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* 红色删除背景（渐变浅红，滑动时渐显） */
.swipe-bg {
  position: absolute;
  inset: 0;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #FF3B30 0%, #FF6B6B 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 0;
  transition: opacity 0.15s ease;
}

.swipe-bg-inner {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 可滑动前景卡片 */
.swipe-foreground {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: flex-start;
  padding: 24rpx 20rpx;
  background: #fff;
  border-radius: 20rpx;
  transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  will-change: transform;
}

.swipe-foreground.swipe-no-trans {
  transition: none;
}

/* 滑动提示指示器（右边缘微渐变，永久暗示可滑动） */
.swipe-hint-edge {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 56rpx;
  background: linear-gradient(90deg, transparent, rgba(255, 59, 48, 0.09));
  z-index: 3;
  pointer-events: none;
  transition: opacity 0.5s ease;
}

.swipe-hint-edge.hint-fade {
  opacity: 0 !important;
  transition: opacity 0.8s ease;
}

/* 首个任务卡的提示脉冲（轻推前闪烁） */
@keyframes hint-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}
.swipe-hint-edge.hint-pulse {
  animation: hint-pulse 1s ease-in-out 2;
}

/* 勾选框 */
.task-checkbox {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 2rpx solid #4A90D9;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin: 6rpx 20rpx 0 0;
  transition: all 0.3s ease;
}

.checkbox-checked {
  background: #34C759;
  border-color: #34C759;
}

/* 任务内容 */
.task-content {
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.task-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.task-title {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  font-weight: 500;
  color: #1A1A2E;
  display: block;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.title-done {
  text-decoration: line-through;
  color: #C0C4CC;
}

.priority-badge {
  flex-shrink: 0;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.priority-high {
  color: #FF3B30;
  background: rgba(255, 59, 48, 0.1);
}

.priority-medium {
  color: #FF9500;
  background: rgba(255, 149, 0, 0.1);
}

.priority-low {
  color: #8A8A9A;
  background: #F0F2F5;
}

.task-desc {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #8A8A9A;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.task-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.meta-chip {
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1.4;
  background: #F5F7FA;
  color: #8A8A9A;
}

.meta-due {
  color: #4A90D9;
  background: rgba(74, 144, 217, 0.1);
}

.meta-repeat {
  color: #6C5CE7;
  background: rgba(108, 92, 231, 0.1);
}

.meta-subtask {
  color: #34C759;
  background: rgba(52, 199, 89, 0.1);
}

.meta-pomodoro {
  color: #FF9500;
  background: rgba(255, 149, 0, 0.1);
}

/* ===== 底部摘要栏 ===== */
.summary-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 32rpx;
  background: linear-gradient(to top, #F5F7FA 60%, transparent);
  z-index: 10;
  pointer-events: none;
}

.summary-left,
.summary-right {
  font-size: 24rpx;
  color: #8A8A9A;
}

.summary-num-green {
  color: #34C759;
  font-weight: 600;
}

.summary-num-blue {
  color: #4A90D9;
  font-weight: 600;
}

/* ===== 悬浮添加按钮 (FAB) ===== */
.fab-btn {
  position: absolute;
  bottom: 80rpx;
  right: 40rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4A90D9 0%, #6C5CE7 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.35);
  z-index: 20;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.fab-btn:active {
  transform: scale(0.92);
  box-shadow: 0 4rpx 12rpx rgba(74, 144, 217, 0.25);
}

/* ===== Task v2 弹窗 ===== */
.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  background: rgba(26, 26, 46, 0.36);
}

.task-sheet {
  width: 100%;
  max-height: 88vh;
  display: flex;
  flex-direction: column;
  border-radius: 36rpx 36rpx 0 0;
  background: #F5F7FA;
  box-shadow: 0 -12rpx 40rpx rgba(0, 0, 0, 0.12);
}

.sheet-handle {
  width: 72rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: #D9DDE6;
  margin: 18rpx auto 10rpx;
}

.sheet-header {
  flex-shrink: 0;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 8rpx 32rpx 20rpx;
}

.sheet-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #1A1A2E;
}

.sheet-subtitle {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #8A8A9A;
}

.sheet-close {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #fff;
}

.sheet-scroll {
  flex: 1;
  height: 0;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.form-section,
.toggle-card {
  margin-bottom: 20rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #fff;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.form-label {
  display: block;
  margin-bottom: 14rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #1A1A2E;
}

.form-input {
  height: 76rpx;
  padding: 0 20rpx;
  border-radius: 16rpx;
  background: #F5F7FA;
  font-size: 28rpx;
  color: #1A1A2E;
}

.form-textarea {
  width: 100%;
  height: 132rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: #F5F7FA;
  font-size: 26rpx;
  color: #1A1A2E;
  box-sizing: border-box;
}

.option-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.option-chip {
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  color: #8A8A9A;
  background: #F5F7FA;
  border: 1rpx solid transparent;
}

.option-active {
  color: #4A90D9;
  background: rgba(74, 144, 217, 0.1);
  border-color: #4A90D9;
  font-weight: 600;
}

.toggle-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.toggle-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A2E;
}

.toggle-desc {
  display: block;
  margin-top: 6rpx;
  font-size: 23rpx;
  color: #8A8A9A;
}

.switch {
  flex-shrink: 0;
  width: 92rpx;
  height: 52rpx;
  padding: 4rpx;
  border-radius: 999rpx;
  background: #D9DDE6;
  box-sizing: border-box;
  transition: background 0.2s ease;
}

.switch view {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #fff;
  transition: transform 0.2s ease;
}

.switch-on {
  background: #4A90D9;
}

.switch-on view {
  transform: translateX(40rpx);
}

.subtask-editor,
.date-time-row,
.repeat-row {
  margin-top: 20rpx;
}

.subtask-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.subtask-input {
  flex: 1;
  height: 68rpx;
  padding: 0 18rpx;
  border-radius: 14rpx;
  background: #F5F7FA;
  font-size: 26rpx;
}

.subtask-remove {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-subtask {
  padding: 16rpx 0 4rpx;
  color: #4A90D9;
  font-size: 26rpx;
  font-weight: 600;
}

.date-time-row {
  display: flex;
  gap: 16rpx;
}

.picker-box {
  min-width: 190rpx;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 18rpx;
  border-radius: 14rpx;
  background: #F5F7FA;
  font-size: 26rpx;
  color: #1A1A2E;
}

.sheet-actions {
  flex-shrink: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 32rpx 34rpx;
  background: linear-gradient(to top, #fff 80%, rgba(255,255,255,0));
}

.cancel-btn,
.save-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
}

.cancel-btn {
  color: #8A8A9A;
  background: #F0F2F5;
}

.save-btn {
  color: #fff;
  background: linear-gradient(135deg, #4A90D9 0%, #6C5CE7 100%);
  box-shadow: 0 8rpx 22rpx rgba(74, 144, 217, 0.26);
}

.save-disabled {
  opacity: 0.7;
}

.sheet-bottom-space {
  height: 20rpx;
}

/* ===== 底部占位空间 ===== */
.scroll-bottom-space {
  height: 160rpx;
}
