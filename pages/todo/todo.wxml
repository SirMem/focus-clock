<!-- ===== 页面容器（flex 撑满全屏） ===== -->
<view class="page-wrapper">

  <!-- ===== 自定义导航栏 ===== -->
  <view class="nav-shell">
    <view class="status-spacer" style="height: {{statusBarHeight}}px;"></view>
    <view class="nav-bar" style="height: {{capsuleHeight}}px;">
      <view class="nav-left">
        <view class="nav-placeholder"></view>
      </view>
      <view class="nav-title">待办事项</view>
      <view class="nav-right" bind:tap="onMenuTap">
        <t-icon name="more" size="44rpx" color="#8A8A9A" />
      </view>
    </view>
  </view>

  <!-- ===== 待办内容区域（flex:1，相对定位用于悬浮子元素） ===== -->
  <view class="todo-area">

    <!-- ===== 快速添加输入框 ===== -->
    <view class="quick-add">
      <view class="quick-add-inner">
        <input
          class="add-input"
          placeholder="快速添加任务..."
          placeholder-style="color:#C0C4CC;font-size:14px"
          value="{{input}}"
          focus="{{inputFocus}}"
          bindinput="onInputChange"
          bindconfirm="onAddTask"
          bindblur="onInputBlur"
          confirm-type="done"
        />
        <view
          class="add-btn {{hasInput ? 'add-btn-active' : ''}}"
          bind:tap="onAddTask"
        >
          <t-icon name="add" size="28rpx" color="{{hasInput ? '#fff' : '#C0C4CC'}}" />
        </view>
      </view>
    </view>

    <!-- ===== 筛选标签 ===== -->
    <view class="filter-chips">
      <view
        wx:for="{{filters}}"
        wx:key="key"
        class="chip {{item.key === filter ? 'chip-active' : ''}}"
        bind:tap="onFilterTap"
        data-key="{{item.key}}"
      >
        <text>{{item.label}}</text>
      </view>
    </view>

    <!-- ===== 任务列表（滚动区域） ===== -->
    <scroll-view class="task-scroll" scroll-y enhanced show-scrollbar="{{false}}" scroll-top="{{scrollTop}}">

      <!-- 空状态 -->
      <view wx:if="{{filteredTasks.length === 0}}" class="empty-state">
        <view class="empty-icon-wrap">
          <text class="empty-icon">📝</text>
        </view>
        <text class="empty-text">{{emptyText}}</text>
      </view>

      <!-- 任务项列表（滑动删除） -->
      <view wx:else class="task-list">
        <view
          wx:for="{{filteredTasks}}"
          wx:key="id"
          class="swipe-wrap"
        >
          <!-- 红色删除背景（滑动时露出） -->
          <view class="swipe-bg" style="opacity: {{item._swipePct || 0}}">
            <view class="swipe-bg-inner">
              <t-icon name="delete" size="40rpx" color="#fff" />
            </view>
          </view>

          <!-- 滑动提示渐变（永久暗示，滑动时渐隐） -->
          <view class="swipe-hint-edge {{item._hintDone ? 'hint-fade' : ''}}"
                style="opacity: {{item._swipePct ? 1 - item._swipePct : 1}}">
          </view>

          <!-- 可滑动任务卡片 -->
          <view
            class="swipe-foreground {{item._swipeNoTrans ? 'swipe-no-trans' : ''}}"
            style="transform: translateX({{item._swipeX || 0}}px)"
            data-id="{{item.id}}"
            bind:touchstart="onTouchStart"
            bind:touchmove="onTouchMove"
            bind:touchend="onTouchEnd"
          >
            <!-- 勾选框 -->
            <view
              class="task-checkbox {{item.done ? 'checkbox-checked' : ''}}"
            >
              <t-icon wx:if="{{item.done}}" name="check" size="24rpx" color="#fff" />
            </view>

            <!-- 任务内容 -->
            <view class="task-content">
              <view class="task-title-row">
                <text class="task-title {{item.done ? 'title-done' : ''}}">{{item.text}}</text>
                <text class="priority-badge priority-{{item.priority}}">{{item.priorityLabel}}</text>
              </view>
              <text wx:if="{{item.description}}" class="task-desc">{{item.description}}</text>
              <view class="task-meta">
                <text wx:if="{{item.hasDue}}" class="meta-chip meta-due">{{item.dueText}}</text>
                <text wx:if="{{item.hasRepeat}}" class="meta-chip meta-repeat">{{item.repeatText}}</text>
                <text wx:if="{{item.hasSubtasks}}" class="meta-chip meta-subtask">{{item.subtaskProgressText}}</text>
                <text class="meta-chip meta-pomodoro">{{item.pomodoroText}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- 底部占位空间（防止内容被底部栏遮挡） -->
      <view class="scroll-bottom-space"></view>
    </scroll-view>

    <!-- ===== 底部摘要栏（悬浮在列表之上） ===== -->
    <view class="summary-bar">
      <text class="summary-left">
        已完成 <text class="summary-num-green">{{doneCount}}</text>/{{tasks.length}}
      </text>
      <text class="summary-right">
        今日专注 <text class="summary-num-blue">{{totalHours}}h{{totalMins}}m</text>
      </text>
    </view>

    <!-- ===== 悬浮添加按钮 (FAB) ===== -->
    <view class="fab-btn" bind:tap="onFabTap">
      <t-icon name="add" size="44rpx" color="#fff" />
    </view>

  </view>

  <!-- ===== Task v2 新建任务弹窗 ===== -->
  <view wx:if="{{showTaskModal}}" class="modal-mask" bind:tap="closeTaskModal">
    <view class="task-sheet" catchtap="stopModalTap">
      <view class="sheet-handle"></view>
      <view class="sheet-header">
        <view>
          <text class="sheet-title">新建任务</text>
          <text class="sheet-subtitle">把任务规划清楚，再开始专注</text>
        </view>
        <view class="sheet-close" bind:tap="closeTaskModal">
          <t-icon name="close" size="36rpx" color="#8A8A9A" />
        </view>
      </view>

      <scroll-view class="sheet-scroll" scroll-y enhanced show-scrollbar="{{false}}">
        <view class="form-section">
          <text class="form-label">任务标题</text>
          <input
            class="form-input"
            placeholder="例如：复习高数第二章"
            value="{{taskForm.title}}"
            maxlength="100"
            bindinput="onFormTitleInput"
          />
        </view>

        <view class="form-section">
          <text class="form-label">任务说明</text>
          <textarea
            class="form-textarea"
            value="{{taskForm.description}}"
            maxlength="500"
            auto-height="{{false}}"
            bindinput="onFormDescriptionInput"
          />
        </view>

        <view class="form-section">
          <text class="form-label">优先级</text>
          <view class="option-row">
            <view
              wx:for="{{priorityOptions}}"
              wx:key="key"
              class="option-chip {{taskForm.priority === item.key ? 'option-active' : ''}}"
              data-key="{{item.key}}"
              bind:tap="onPrioritySelect"
            >{{item.label}}</view>
          </view>
        </view>

        <view class="form-section">
          <text class="form-label">预计番茄</text>
          <view class="option-row">
            <view
              wx:for="{{pomodoroOptions}}"
              wx:key="*this"
              class="option-chip {{taskForm.estimatedPomodoros === item ? 'option-active' : ''}}"
              data-value="{{item}}"
              bind:tap="onPomodoroSelect"
            >🍅 {{item}}</view>
          </view>
        </view>

        <view class="toggle-card">
          <view class="toggle-head" bind:tap="toggleFormSubtasks">
            <view>
              <text class="toggle-title">拆分子任务</text>
              <text class="toggle-desc">适合复杂任务，按步骤推进</text>
            </view>
            <view class="switch {{taskForm.enableSubtasks ? 'switch-on' : ''}}"><view></view></view>
          </view>
          <view wx:if="{{taskForm.enableSubtasks}}" class="subtask-editor">
            <view wx:for="{{taskForm.subtasks}}" wx:key="id" class="subtask-row">
              <input
                class="subtask-input"
                value="{{item.title}}"
                data-index="{{index}}"
                bindinput="onSubtaskInput"
              />
              <view class="subtask-remove" data-index="{{index}}" bind:tap="removeSubtask">
                <t-icon name="close-circle" size="34rpx" color="#C0C4CC" />
              </view>
            </view>
            <view class="add-subtask" bind:tap="addSubtask">+ 添加步骤</view>
          </view>
        </view>

        <view class="toggle-card">
          <view class="toggle-head" bind:tap="toggleFormDue">
            <view>
              <text class="toggle-title">设置截止时间</text>
              <text class="toggle-desc">让今天必须完成的任务更明确</text>
            </view>
            <view class="switch {{taskForm.enableDue ? 'switch-on' : ''}}"><view></view></view>
          </view>
          <view wx:if="{{taskForm.enableDue}}" class="date-time-row">
            <picker mode="date" value="{{taskForm.dueDate}}" bindchange="onDueDateChange">
              <view class="picker-box">{{taskForm.dueDate}}</view>
            </picker>
            <picker mode="time" value="{{taskForm.dueTime}}" bindchange="onDueTimeChange">
              <view class="picker-box">{{taskForm.dueTime}}</view>
            </picker>
          </view>
        </view>

        <view class="toggle-card">
          <view class="toggle-head" bind:tap="toggleFormRepeat">
            <view>
              <text class="toggle-title">重复任务</text>
              <text class="toggle-desc">适合习惯、复盘、周期任务</text>
            </view>
            <view class="switch {{taskForm.enableRepeat ? 'switch-on' : ''}}"><view></view></view>
          </view>
          <view wx:if="{{taskForm.enableRepeat}}" class="option-row repeat-row">
            <view
              wx:for="{{repeatOptions}}"
              wx:key="key"
              class="option-chip {{taskForm.repeatType === item.key ? 'option-active' : ''}}"
              data-key="{{item.key}}"
              bind:tap="onRepeatSelect"
            >{{item.label}}</view>
          </view>
        </view>

        <view class="sheet-bottom-space"></view>
      </scroll-view>

      <view class="sheet-actions">
        <view class="cancel-btn" bind:tap="closeTaskModal">取消</view>
        <view class="save-btn {{savingTask ? 'save-disabled' : ''}}" bind:tap="saveTaskFromModal">
          {{savingTask ? '保存中...' : '保存任务'}}
        </view>
      </view>
    </view>
  </view>

</view>
