.timer-container {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  width: 480rpx;
  height: 480rpx;
}
.timer-canvas {
  position: absolute;
  top: 0;
  left: 0;
  width: 480rpx;
  height: 480rpx;
}
.time-display {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  pointer-events: none;
  z-index: 1;
}
.time-text {
  font-size: 88rpx;
  font-weight: 700;
  color: #1A1A2E;
  letter-spacing: 4rpx;
  line-height: 1.2;
}
.state-label {
  font-size: 28rpx;
  color: #8A8A9A;
  margin-top: 8rpx;
  font-weight: 500;
}
