.timer-container {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  width: 600rpx;
  height: 600rpx;
}

.timer-glow {
  position: absolute;
  top: 75rpx;
  right: 75rpx;
  bottom: 75rpx;
  left: 75rpx;
  border-radius: 50%;
  opacity: 0.15;
  filter: blur(48rpx);
}

.timer-canvas {
  position: relative;
  z-index: 1;
  width: 600rpx;
  height: 600rpx;
}

.time-display {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  pointer-events: none;
  z-index: 2;
}

.time-text {
  font-size: 96rpx;
  font-weight: 700;
  color: #1A1A2E;
  letter-spacing: -2rpx;
  line-height: 1;
  font-family: -apple-system, 'PingFang SC', sans-serif;
}

.state-label {
  font-size: 28rpx;
  line-height: 1.4;
  margin-top: 16rpx;
  font-weight: 500;
}
